      "settings": {
        "fontStyle": "bold",
        "foreground": "#e06c75"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#98c379"
      }
    },
    {
      "scope": ["markup.deleted"],
      "settings": {
        "foreground": "#e06c75"
      }
