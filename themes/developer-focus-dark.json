      "settings": {
        "foreground": "#61afef"
      }
    },
    {
      "scope": ["entity.name.class", "entity.name.type.class"],
      "settings": {
        "foreground": "#e5c07b"
      }
    },
    {
      "scope": ["entity.name.type"],
      "settings": {
        "foreground": "#e5c07b"
      }
    },
    {
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#e06c75"
      }
    },
    {
