    {
      "scope": ["invalid"],
      "settings": {
        "foreground": "#f85149"
      }
    },
    {
      "scope": ["invalid.deprecated"],
      "settings": {
        "foreground": "#d19a66"
      }
    },
    {
      "scope": ["invalid.illegal"],
      "settings": {
        "foreground": "#f85149"
      }
