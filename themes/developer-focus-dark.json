    {
      "scope": ["support.function"],
      "settings": {
        "foreground": "#56b6c2"
      }
    },
    {
      "scope": ["support.class"],
      "settings": {
        "foreground": "#e5c07b"
      }
    },
    {
      "scope": ["support.type"],
      "settings": {
        "foreground": "#56b6c2"
      }
    },
    {
      "scope": ["meta.property-name"],
      "settings": {
        "foreground": "#e06c75"
      }
    },
    {
      "scope": ["meta.property-value"],
      "settings": {
        "foreground": "#d19a66"
      }
    },
    {
      "scope": ["meta.preprocessor"],
      "settings": {
        "foreground": "#abb2bf"
      }
    },
    {
      "scope": ["meta.preprocessor.string"],
      "settings": {
        "foreground": "#98c379"
      }
    },
    {
      "scope": ["meta.preprocessor.numeric"],
      "settings": {
        "foreground": "#d19a66"
      }
    },
    {
      "scope": ["meta.header.diff"],
      "settings": {
        "foreground": "#c678dd"
      }
    },
    {
      "scope": ["storage"],
      "settings": {
        "foreground": "#c678dd"
      }
    },
    {
      "scope": ["storage.modifier"],
      "settings": {
        "foreground": "#c678dd"
      }
    },
    {
