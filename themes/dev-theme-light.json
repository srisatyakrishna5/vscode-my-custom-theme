  "tokenColors": [
    {
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#8A9097",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["comment.block.documentation", "comment.line.documentation"],
      "settings": {
        "foreground": "#98A0A8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["keyword", "storage", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#7A4FB0"
      }
    },
    {
      "scope": ["keyword.control", "keyword.operator"],
      "settings": {
        "foreground": "#8A63BC"
      }
    },
    {
      "scope": ["punctuation.accessor"],
      "settings": {
        "foreground": "#7B8794"
      }
    },
    {
      "scope": ["string", "string.quoted", "string.template", "string.regexp"],
      "settings": {
        "foreground": "#6E8B5E"
      }
    },
    {
      "scope": ["constant.numeric", "constant.language", "support.constant", "keyword.other.unit"],
      "settings": {
        "foreground": "#B88453"
      }
    },
    {
      "scope": ["variable", "support.variable"],
      "settings": {
        "foreground": "#35404A"
      }
    },
    {
      "scope": ["variable.parameter", "variable.other.constant"],
      "settings": {
        "foreground": "#B85A00"
      }
    },
    {
      "scope": ["variable.other.property", "meta.property-name", "entity.other.attribute-name", "meta.object-literal.key"],
      "settings": {
        "foreground": "#0E7F8C"
      }
    },
    {
      "scope": [
        "variable.parameter.function",
        "meta.function.parameters variable.other.readwrite",
        "meta.parameters variable.other.readwrite",
        "meta.function.parameters.python variable.parameter",
        "meta.function-call.arguments variable.parameter"
      ],
      "settings": {
        "foreground": "#B85A00"
      }
    },
    {
      "scope": [
        "meta.object-literal.key.js",
        "meta.object-literal.key.ts",
        "meta.object-literal.key.jsx",
        "meta.object-literal.key.tsx",
        "meta.mapping.key.yaml",
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#007C89"
      }
    },
    {
      "scope": ["entity.name.function", "support.function", "meta.function-call", "variable.function"],
      "settings": {
        "foreground": "#5F7FA8"
      }
    },
    {
      "scope": [
        "entity.name.function.js",
        "entity.name.function.ts",
        "entity.name.function.python",
        "meta.function-call.js entity.name.function",
        "meta.function-call.ts entity.name.function",
        "meta.function-call.python entity.name.function"
      ],
      "settings": {
        "foreground": "#3D69A8"
      }
    },
    {
      "scope": [
        "variable.other.readwrite.js",
        "variable.other.readwrite.ts",
        "meta.destructuring variable.other.readwrite",
        "meta.object-binding-pattern-variable",
        "meta.array-binding-pattern-variable"
      ],
      "settings": {
        "foreground": "#2F3E4A"
      }
    },
    {
      "scope": ["entity.name.type", "entity.name.class", "support.class", "support.type"],
      "settings": {
        "foreground": "#A08A4A"
      }
    },
    {
      "scope": ["entity.name.namespace", "entity.name.module"],
      "settings": {
        "foreground": "#5E8FA3"
      }
    },
    {
      "scope": ["entity.name.tag", "meta.tag.sgml", "punctuation.definition.tag"],
      "settings": {
        "foreground": "#5F7FA8"
      }
    },
    {
      "scope": ["entity.other.attribute-name.html", "entity.other.attribute-name.css"],
      "settings": {
        "foreground": "#B88453"
      }
    },
    {
      "scope": ["support.type.property-name.css", "variable.css", "variable.scss"],
      "settings": {
        "foreground": "#5E8FA3"
      }
    },
    {
      "scope": ["markup.heading", "markdown.heading"],
      "settings": {
        "foreground": "#5F7FA8",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.bold", "punctuation.definition.bold"],
      "settings": {
        "foreground": "#A08A4A",
        "fontStyle": "bold"
      }
    },
    {
      "scope": ["markup.italic", "punctuation.definition.italic"],
      "settings": {
        "foreground": "#8F79A8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["markup.inline.raw", "markup.fenced_code.block.markdown"],
      "settings": {
        "foreground": "#6E8B5E"
      }
    },
    {
      "scope": ["markup.inserted"],
      "settings": {
        "foreground": "#6E8B5E"
      }
    },
    {
      "scope": ["markup.deleted", "invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#C77A6D"
      }
    }
  ]
}