{
  "name": "deep-focus",
  "displayName": "Deep Focus Themes",
  "description": "Soft, low-fatigue VS Code color themes for long developer sessions.",
  "version": "1.1.0",
  "publisher": "deep-focus",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Themes"
  ],
  "keywords": [
    "dark",
    "light",
    "professional",
    "minimal",
    "eye-strain",
    "productivity",
    "clean",
    "developer",
    "accessibility",
    "soft-colors"
  ],
  "repository": {
    "url": "https://github.com/srisatyakrishna5/vscode-my-custom-theme",
    "type": "git",
    "directory": ""
  },
  "contributes": {
    "themes": [
      {
        "label": "Deep Focus Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/deep-focus-dark.json"
      },
      {
        "label": "Deep Focus Light",
        "uiTheme": "vs",
        "path": "./themes/deep-focus-light.json"
      },
      {
        "label": "Dev Theme Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/dev-theme-dark.json"
      },
      {
        "label": "Dev Theme Light",
        "uiTheme": "vs",
        "path": "./themes/dev-theme-light.json"
      }
    ]
  },
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
